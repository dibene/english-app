# Speech-to-Text Provider Configuration
DEEPGRAM_API_KEY=your_deepgram_api_key_here
STT_PROVIDER=deepgram

# Pronunciation Assessment Provider Configuration
# See README.md > Architecture Decisions > ADR-001 for setup instructions
# How to get keys: portal.azure.com -> Create resource -> Speech -> Free F0 (5 hrs/month)
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus
PRONUNCIATION_PROVIDER=azure

# Large Language Model Provider Configuration
# No OpenAI account required. Three free-tier options (pick one):
#
# Option A — Gemini 2.0 Flash (recommended, best quality/price, free tier without card)
#   Get key: aistudio.google.com/apikey
#   LLM_API_KEY=your_gemini_api_key_here
#   LLM_MODEL=gemini-2.0-flash
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#
# Option B — Groq / Llama 3.3 70B (free tier without card)
#   Get key: console.groq.com/keys
#   LLM_API_KEY=your_groq_api_key_here
#   LLM_MODEL=llama-3.3-70b-versatile
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#
# Option C — Ollama local (no key needed, needs ollama installed)
#   Install: curl -fsSL https://ollama.com/install.sh | sh && ollama pull llama3.2:8b
#   LLM_API_KEY=ollama
#   LLM_MODEL=llama3.2:8b
#   LLM_BASE_URL=http://localhost:11434/v1
#
# Option D — OpenAI gpt-4o-mini (paid, requires credit card)
#   LLM_API_KEY=your_openai_api_key_here
#   LLM_MODEL=gpt-4o-mini
#   LLM_BASE_URL=   # leave empty for OpenAI default
#
LLM_API_KEY=
LLM_MODEL=gemini-2.0-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_PROVIDER selects the provider *class*, not the service.
# "openai" = use the OpenAI-compatible protocol class (works with Gemini, Groq, Ollama, OpenAI).
# Only one class exists today — keep this value as-is regardless of which service you pick.
LLM_PROVIDER=openai

# Application Configuration
ENV=development
LOG_LEVEL=INFO

# Speech-to-Text Provider Configuration
DEEPGRAM_API_KEY=your_deepgram_api_key_here
STT_PROVIDER=deepgram

# Pronunciation Assessment Provider Configuration
# See README.md > Architecture Decisions > ADR-001 for setup instructions
# How to get keys: portal.azure.com -> Create resource -> Speech -> Free F0 (5 hrs/month)
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus
PRONUNCIATION_PROVIDER=azure

# Large Language Model Provider Configuration
OPENAI_API_KEY=your_openai_api_key_here
LLM_PROVIDER=openai

# Application Configuration
ENV=development
LOG_LEVEL=INFO
